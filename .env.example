# Groq API Key (Llama 3.3 70b)
GROQ_API_KEY=your_groq_api_key_here

# Email SMTP Settings (Gmail)
GMAIL_USER=your_sender@gmail.com
GMAIL_APP_PASSWORD=your_16_char_gmail_app_password

# Email Recipients
RECIPIENT_EMAIL=primary_recipient@example.com

# Multi-CC Support: You can add multiple CC recipients by defining keys starting with RECIPIENT_CC
# E.g., RECIPIENT_CC_1, RECIPIENT_CC_2, etc.
RECIPIENT_CC_1=cc_person1@example.com
RECIPIENT_CC_2=cc_person2@example.com

# NewsAPI Key (Optional, free tier from newsapi.org)
NEWSAPI_KEY=your_newsapi_key_here_optional
